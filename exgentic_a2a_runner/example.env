# Example Environment Configuration for Exgentic A2A Runner
# Copy this file to .env and customize for your environment

# ============================================================
# CLUSTER TARGET (Optional)
# ============================================================

# Set INGRESS_DOMAIN to target an OpenShift cluster from your laptop.
# URLs will use https://<service>-<namespace>.<INGRESS_DOMAIN>
# Leave unset for Kind / localtest.me (default).
# Example (ykt3 OpenShift):
# INGRESS_DOMAIN=apps.ykt3.hcp.res.ibm.com

# Master-realm Keycloak admin credentials (used to enable direct access grants).
# Auto-fetched from the keycloak-initial-admin cluster secret; override if needed.
# KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD=admin

# ============================================================
# AUTOMATICALLY SETUP CONFIGURATION
# ============================================================

# NOTE: When using evaluate_benchmark.sh, EXGENTIC_MCP_SERVER_URL and A2A_BASE_URL
# are automatically set based on the deployment method:
# - With createHttpRoute=true: Uses HTTP route URLs (e.g., http://<service>.team1.localtest.me:8080)
# - With port-forwarding: Uses localhost URLs (e.g., http://localhost:7770)
# You only need to set them manually if running the runner directly without the script.

# Exgentic MCP Server URL (set automatically by evaluate_benchmark.sh)
# With HTTP routes: http://exgentic-mcp-<benchmark>.team1.localtest.me:8080/mcp
# With port-forward: http://localhost:7770/mcp
# EXGENTIC_MCP_SERVER_URL=http://exgentic-mcp-gsm8k.team1.localtest.me:8080/mcp

# A2A endpoint base URL (set automatically by evaluate_benchmark.sh)
# With HTTP routes: http://<agent-name>-<benchmark>.team1.localtest.me:8080
# With port-forward: http://localhost:7701
# A2A_BASE_URL=http://exgentic-a2a-tool-calling-gsm8k.team1.localtest.me:8080


# ============================================================
# EXGENTIC CONFIGURATION (Optional)
# ============================================================

# MCP operation timeout in seconds (default: 60)
EXGENTIC_MCP_TIMEOUT_SECONDS=60

# Maximum number of tasks/sessions to process (useful for testing)
MAX_TASKS=1

# Maximum number of parallel sessions to run concurrently (default: 1)
# Set to 1 for sequential processing, higher values for parallel execution
# Example: MAX_PARALLEL_SESSIONS=5 will run up to 5 sessions simultaneously
MAX_PARALLEL_SESSIONS=1   

# Stop processing on first failure (default: false)
ABORT_ON_FAILURE=false

# ============================================================
# A2A CONFIGURATION (Optional)
# ============================================================

# Request timeout in seconds (default: 300)
A2A_TIMEOUT_SECONDS=600

# Bearer token for authentication (if required by your endpoint)
# A2A_AUTH_TOKEN=your-secret-token-here

# Verify TLS certificates (default: true)
A2A_VERIFY_TLS=true

# Custom endpoint path (default: /v1/chat)
# For A2A JSON-RPC protocol, use root path
A2A_ENDPOINT_PATH=/

# ============================================================
# OPENTELEMETRY CONFIGURATION (Optional)
# ============================================================

# Service name for telemetry (default: exgentic-a2a-runner)
OTEL_SERVICE_NAME=exgentic-a2a-runner

# OTLP exporter endpoint (if not set, telemetry won't be exported and no console output)
# For local Jaeger: uncomment the line below after starting Jaeger with Docker
# See README.md "OpenTelemetry and Observability" section for setup instructions
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP protocol (default: grpc)
# Options: grpc, http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Additional resource attributes (comma-separated key=value pairs)
# OTEL_RESOURCE_ATTRIBUTES=env=development,team=research,version=1.0

# Enable requests auto-instrumentation for standardized HTTP client spans (default: true)
OTEL_INSTRUMENT_REQUESTS=true

# Use insecure connection for OTLP (default: true)
# Set to false if using TLS-enabled collector
OTEL_EXPORTER_OTLP_INSECURE=true

# ============================================================
# MCP GATEWAY CONFIGURATION (Optional)
# ============================================================

# Enable MCP Gateway routing (default: false)
# When enabled, the benchmark MCP server is registered with the gateway
# and the agent connects via the gateway instead of directly
USE_MCP_GATEWAY=false

# MCP tool name prefix applied by the gateway (default: empty)
# When using the MCP gateway, tools are exposed with a prefix (e.g. "exgentic_")
# so "list_tasks" becomes "exgentic_list_tasks". Set this to match the gateway config.
# EXGENTIC_MCP_TOOL_PREFIX=exgentic_

# ============================================================
# AUTHBRIDGE PIPELINE COMPOSITION (Optional)
# ============================================================
# Composition of the AuthBridge plugin pipeline is driven entirely by
# command-line flags on deploy-agent.sh / deploy-and-evaluate.sh:
#
#   --plugin-preset {auth-only|ibac-only|full}
#   --plugin <name>[:enforce|observe|off]   (repeatable)
#   --plugin <name>                         (default policy: enforce)
#   --no-plugin <name>                      (shorthand for --plugin <name>:off)
#   --plugin-config-file <path>             (flat-map per-plugin overrides)
#
#
# Prerequisite: the cluster's authbridge sidecar image must include
# every plugin in the resolved selection. Older chart pins may lack
# newer plugins (`ibac`, `token-broker`).
#
# The variables below are read by the corresponding plugin's YAML
# fragment (in authbridge/plugins/) via envsubst — they only matter
# when that plugin is in the active set.

# --- IBAC plugin tunables ---
# Judge LLM base URL. Must be OpenAI-compatible (POST /v1/chat/completions).
# Default targets ollama on the host.
# IBAC_JUDGE_ENDPOINT=http://host.docker.internal:11434

# Judge model id served by the endpoint above.
# IBAC_JUDGE_MODEL=llama3.2:3b

# Hostname of the agent's own LLM endpoint. Added to the IBAC bypass list so
# the agent's reasoning calls aren't recursively judged. Auto-derived from
# OPENAI_API_BASE if unset; defaults to host.docker.internal otherwise.
# IBAC_AGENT_LLM_HOST=host.docker.internal

# Per-judge-call timeout in milliseconds. Bump if the judge model is slow.
# IBAC_TIMEOUT_MS=15000

# --- token-broker plugin tunables (mutex with token-exchange) ---
# Broker URL and audience (only consumed when token-broker is active).
# TOKEN_BROKER_URL=http://broker.example/exchange
# TOKEN_BROKER_AUDIENCE=my-broker-aud

# ============================================================
# DEBUG CONFIGURATION (Optional)
# ============================================================

# Log level (default: INFO)
# Set to DEBUG to enable verbose logging with detailed debug information
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Log prompt details (default: 0)
#LOG_PROMPT=0

# Log response details (default: 0)
#LOG_RESPONSE=0
